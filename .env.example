############################################
# probe-shield isolated env
############################################

PROBE_SHIELD_HTTP_ADDRESS=0.0.0.0
PROBE_SHIELD_HTTP_PORT=4000

# If login or password is empty, successful authentication is impossible.
PROBE_SHIELD_LOGIN=
PROBE_SHIELD_PASSWORD=

PROBE_SHIELD_RL_WINDOW=5m
PROBE_SHIELD_RL_MAX_FAILURES=10

# Optional branding. Title is also used as the browser <title> after color tags are stripped.
# Title supports the original colored text syntax, for example: {8195a3}Exo{eceddb}dus
PROBE_SHIELD_BRAND_TITLE=
PROBE_SHIELD_BRAND_DESCRIPTION=
PROBE_SHIELD_BRAND_LOGO_URL=

# Optional response headers. If JSON contains at least one header, only these headers are emitted.
PROBE_SHIELD_RESPONSE_HEADERS_ENABLED=true
# Example JSON override: {"X-Content-Type-Options":"nosniff"}
PROBE_SHIELD_RESPONSE_HEADERS_JSON=
